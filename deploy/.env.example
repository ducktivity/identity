# Box runtime env for the identity stack. Copy to `.env.prod` and fill it in, then `deploy/secrets.sh encrypt` to write the committed, SOPS-encrypted `.env.sops`. On each deploy the box sops-decrypts that into /opt/ducktivity/identity/deploy/.env (mode 600), which compose auto-loads. Not consumed by CI — CI only migrates + builds; the box holds these values.

ENV=prod
ISSUER=https://id.ducktvt.com

# Structured logging. Optional — box defaults to info + json.
LOG_LEVEL=info
LOG_FORMAT=json

# Sentry error tracking (getsentry DSN). Empty disables it.
SENTRY_DSN=

# Crown jewel: base64 of a 32-byte Ed25519 seed. `openssl rand -base64 32`. STABLE FOREVER — rotating it logs out the whole suite.
AUTH_SIGNING_KEY=

# Peppers login-code hashes. `openssl rand -base64 32`. Required in prod.
AUTH_CODE_PEPPER=

# Resend API key for login emails. Empty = codes logged instead of emailed.
RESEND_API_KEY=
AUTH_EMAIL_FROM=Ducktivity <onboarding@resend.dev>

# App-role Neon string (least privilege, DML only). NOT the migrator role.
DATABASE_URL=

# Optional stub (billing deferred). Leave unset unless/until billing lands.
# STRIPE_WEBHOOK_SECRET=
